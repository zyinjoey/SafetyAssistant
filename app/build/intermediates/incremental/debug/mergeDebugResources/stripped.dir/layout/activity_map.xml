<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/module_map"
        app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
        app:title="@string/map_title"
        app:titleTextColor="@color/text_on_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_location"
            android:tint="@color/module_map" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/map_tip"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_locate"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/btn_primary_rounded"
            android:text="@string/map_locate"
            android:textColor="@color/text_on_primary"
            android:textSize="16sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_background"
        android:elevation="16dp"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_police"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/map_nearby_police"
                android:textSize="14sp"
                app:chipBackgroundColor="@color/chip_background"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="@color/module_safe"
                app:chipStrokeWidth="1dp"
                app:closeIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_bank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/map_nearby_bank"
                android:textSize="14sp"
                app:chipBackgroundColor="@color/chip_background"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="@color/module_map"
                app:chipStrokeWidth="1dp"
                app:closeIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_operator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/map_nearby_operator"
                android:textSize="14sp"
                app:chipBackgroundColor="@color/chip_background"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="@color/primary"
                app:chipStrokeWidth="1dp"
                app:closeIconVisible="false" />

        </com.google.android.material.chip.ChipGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/search_input_background"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="8dp"
                android:hint="@string/map_search_hint"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_search"
                android:layout_width="80dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/btn_primary_rounded"
                android:text="搜索"
                android:textColor="@color/text_on_primary"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>