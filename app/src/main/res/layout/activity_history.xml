<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/module_history"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:title="@string/history_title"
            app:titleTextColor="@color/text_on_primary" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Tab 切换 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/card_background"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tab_check"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="12dp"
                android:text="@string/history_check"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_medium"
                android:background="@drawable/button_background" />

            <TextView
                android:id="@+id/tab_scan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="12dp"
                android:text="@string/history_scan"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_medium" />

            <TextView
                android:id="@+id/tab_sos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="12dp"
                android:text="@string/history_sos"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_medium" />

            <TextView
                android:id="@+id/tab_study"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="12dp"
                android:text="@string/history_study"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_medium" />

        </LinearLayout>

        <!-- 空状态 -->
        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/history_empty"
            android:textColor="@color/text_hint"
            android:textSize="@dimen/text_size_large"
            android:visibility="gone" />

        <!-- 记录列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_records"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/padding_medium" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>